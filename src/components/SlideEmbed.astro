---
interface Props {
  src: string
  title: string
  orientation?: 'landscape' | 'portrait'
  float?: 'right' | 'left'
  pdf?: string
}
const { src, title, orientation = 'landscape', float, pdf } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const resolvedSrc = base + src
const resolvedPdf = pdf ? base + pdf : undefined
---

<div class:list={['slide-embed', `slide-embed--${orientation}`, float && `slide-embed--float-${float}`]}>
  <iframe src={resolvedSrc} title={title}></iframe>
  {resolvedPdf
    ? <a href={resolvedPdf} target="_blank" rel="noopener noreferrer">Download PDF ↓</a>
    : <a href={resolvedSrc} target="_blank" rel="noopener noreferrer">Open slides ↗</a>
  }
</div>

<style>
  .slide-embed {
    margin: 1rem 0;
  }
  .slide-embed iframe {
    width: 100%;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
  }
  .slide-embed--landscape iframe {
    aspect-ratio: 16 / 9;
  }
  .slide-embed--portrait {
    width: 60%;
  }
  .slide-embed--portrait iframe {
    aspect-ratio: 210 / 297;
  }
  .slide-embed--float-right {
    float: right;
    width: 48%;
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .slide-embed--float-left {
    float: left;
    width: 48%;
    margin-right: 1.5rem;
    margin-bottom: 1rem;
  }
  .slide-embed a {
    display: block;
    margin-top: 0.5rem;
    text-align: right;
    font-size: 0.9em;
  }
</style>
